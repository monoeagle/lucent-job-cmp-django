# MPP Django — Produktions-Umgebung (Vorlage)
#
# Kopieren und Werte einsetzen. Auf der VM wird diese Datei per systemd
# EnvironmentFile injiziert (z.B. /etc/mpp/mpp.env) oder als mpp/.env abgelegt.
# NIEMALS die echte .env committen — sie ist in .gitignore ausgeschlossen.
#
# Lädt config.settings.production. Siehe docs/deployment/vm-installation.md.

# ── Pflicht ──────────────────────────────────────────────────────────────────

# Zufälliger, geheimer Schlüssel. Erzeugen mit:
#   python3 -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# Kommagetrennte Liste der erlaubten Hostnamen (kein Schema, kein Slash).
ALLOWED_HOSTS=mpp.example.com,www.mpp.example.com

# PostgreSQL-Verbindung als URL: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://mpp:CHANGE_ME@127.0.0.1:5432/mpp_prod

# ── Optional (sinnvolle Defaults in production.py) ───────────────────────────

# DEBUG MUSS in Produktion False bleiben (Default). Niemals auf True setzen.
DEBUG=False

# Redis als Celery-Broker/Backend.
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# Vertrauenswürdige Origins für CSRF (mit Schema!), kommagetrennt.
CSRF_TRUSTED_ORIGINS=https://mpp.example.com,https://www.mpp.example.com

# TLS-Redirect (Default True). Nur in Spezialfällen (z.B. internes Staging
# ohne TLS) auf False setzen.
SECURE_SSL_REDIRECT=True

# HSTS-Dauer in Sekunden (Default 31536000 = 1 Jahr).
SECURE_HSTS_SECONDS=31536000

# Persistente DB-Verbindungen in Sekunden (Default 60).
DB_CONN_MAX_AGE=60
